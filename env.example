# AI图像生成API服务配置
# /generate-async/ 请求必须显式传 provider；可通过 GET /provider-options 查看可选 provider 与参数关系。

# BFL API配置（请求 provider=flux_bfl 时必需）
BFL_API_KEY=your_bfl_api_key_here
BFL_BASE_URL=https://api.bfl.ai/v1  # 可选，默认为官方API地址

# Replicate API配置（请求 provider=flux_replicate、gemini-nanobanana_replicate 或 seedream-4_replicate 时必需）
REPLICATE_API_TOKEN=your_replicate_token_here

# Gemini API配置（请求 provider=gemini-nanobanana_google 时必需）
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Fireworks API配置
FIREWORKS_API_KEY=your_fireworks_api_key_here

# OpenRouter API配置
OPENROUTER_API_KEY=your_openrouter_api_key_here

# fal.ai API配置
FAL_API_KEY=your_fal_api_key_here

# aiapiroute/Sub2API GPT-image 配置（请求 provider=aiapiroute_gpt-image-* 时必需）
AIAPIROUTE_API_KEY=your_aiapiroute_or_sub2api_user_key_here
AIAPIROUTE_BASE_URL=https://aiapiroute.com
AIAPIROUTE_GPT_IMAGE1_MODEL=gpt-image-1
AIAPIROUTE_GPT_IMAGE15_MODEL=gpt-image-1.5
AIAPIROUTE_GPT_IMAGE2_MODEL=gpt-image-2
# 可选: 1K / 2K / 4K / auto；请求表单中的 size 字段会覆盖此默认值
AIAPIROUTE_IMAGE_RESOLUTION=1K
AIAPIROUTE_IMAGE_QUALITY=
AIAPIROUTE_IMAGE_STREAM=true
AIAPIROUTE_TIMEOUT_SECONDS=300

# 算法配置
ALGORITHM_FACTOR=6987

# 其他配置
DEBUG=False
CORS_ORIGINS=*
MAX_CONCURRENT_TASKS=5
ADMIN_API_KEY=
MAX_UPLOAD_FILES=4
MAX_UPLOAD_FILE_MB=20
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp

# AI图像生成API服务配置 flux_bfl / flux_replicate / flux_fireworks / gemini-nanobanana_google / gemini-nanobanana_replicate / gemini-nanobanana_openrouter / seedream-4_replicate / seedream-4_fal / aiapiroute_gpt-image-1 / aiapiroute_gpt-image-1.5 / aiapiroute_gpt-image-2
IMAGE_GENERATION_PROVIDER=gemini-nanobanana_openrouter

# BFL API配置（当IMAGE_GENERATION_PROVIDER=flux_bfl时必需）
BFL_API_KEY=your_bfl_api_key_here
BFL_BASE_URL=https://api.bfl.ai/v1  # 可选，默认为官方API地址

# Replicate API配置（当IMAGE_GENERATION_PROVIDER=flux_replicate时必需）
REPLICATE_API_TOKEN=your_replicate_token_here

# Gemini API配置 (当 IMAGE_GENERATION_PROVIDER=gemini_google 时使用)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Fireworks API配置
FIREWORKS_API_KEY=your_fireworks_api_key_here

# OpenRouter API配置
OPENROUTER_API_KEY=your_openrouter_api_key_here

# fal.ai API配置
FAL_API_KEY=your_fal_api_key_here

# aiapiroute/Sub2API GPT-image 配置（当 IMAGE_GENERATION_PROVIDER=aiapiroute_gpt-image-* 时必需）
AIAPIROUTE_API_KEY=your_aiapiroute_or_sub2api_user_key_here
AIAPIROUTE_BASE_URL=https://aiapiroute.com
AIAPIROUTE_GPT_IMAGE1_MODEL=gpt-image-1
AIAPIROUTE_GPT_IMAGE15_MODEL=gpt-image-1.5
AIAPIROUTE_GPT_IMAGE2_MODEL=gpt-image-2
AIAPIROUTE_GPT_IMAGE2_RESOLUTION=1K
AIAPIROUTE_GPT_IMAGE2_QUALITY=
AIAPIROUTE_GPT_IMAGE2_STREAM=true
AIAPIROUTE_TIMEOUT_SECONDS=300

# 算法配置
ALGORITHM_FACTOR=6987

# 其他配置
DEBUG=False
CORS_ORIGINS=*
MAX_CONCURRENT_TASKS=5


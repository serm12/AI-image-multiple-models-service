# AI图像生成API服务配置 flux_bfl / flux_replicate / flux_fireworks / gemini_google / gemini_replicate / gemini_openrouter / seedream-4_replicate / seedream-4_fal
IMAGE_GENERATION_PROVIDER=gemini_openrouter

# BFL API配置（当IMAGE_GENERATION_PROVIDER=flux_bfl时必需）
BFL_API_KEY=your_bfl_api_key_here
BFL_BASE_URL=https://api.bfl.ai/v1  # 可选，默认为官方API地址

# Replicate API配置（当IMAGE_GENERATION_PROVIDER=flux_replicate时必需）
REPLICATE_API_TOKEN=your_replicate_token_here

# Gemini API配置 (当 IMAGE_GENERATION_PROVIDER=gemini_google 时使用)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Fireworks API配置
FIREWORKS_API_KEY=your_fireworks_api_key_here

# OpenRouter API配置
OPENROUTER_API_KEY=your_openrouter_api_key_here

# fal.ai API配置
FAL_API_KEY=your_fal_api_key_here

# 算法配置
ALGORITHM_FACTOR=6987

# 其他配置
DEBUG=False
CORS_ORIGINS=*
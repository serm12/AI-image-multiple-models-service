# AI图像生成API服务配置
IMAGE_GENERATION_PROVIDER=flux_bfl

# BFL API配置 (当 IMAGE_GENERATION_PROVIDER=flux_bfl 时使用)
BFL_API_KEY=your_bfl_api_key_here
BFL_BASE_URL=https://api.bfl.ai/v1  # 可选，默认为官方API地址

# Replicate API配置 (当 IMAGE_GENERATION_PROVIDER=flux_replicate 时使用)
REPLICATE_API_TOKEN=your_replicate_token_here

# Fireworks AI API配置 (当 IMAGE_GENERATION_PROVIDER=flux_fireworks 时使用)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Gemini API配置 (当 IMAGE_GENERATION_PROVIDER=gemini_google 时使用)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini Replicate API配置 (当 IMAGE_GENERATION_PROVIDER=gemini_replicate 时使用)
# 使用相同的 REPLICATE_API_TOKEN

# 其他配置
DEBUG=false
CORS_ORIGINS=*
ALGORITHM_FACTOR=6987 